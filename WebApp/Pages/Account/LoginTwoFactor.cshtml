@page
@model WebApp.Pages.Account.LoginTwoFactorModel
@{
}

<h3>Please enter the code from your email</h3>
<br />
<div class="container border" style="padding:20px">
    <form method="post">
        <div class="text-danger" asp-validation-summary="All"></div>
        <div class="row mb-3">
            <div class="col-2">
                <label asp-for="EmailMFA.MFAToken"></label>
            </div>
            <div class="col-5">
                <input type="text" asp-for="EmailMFA.MFAToken" class="form-control" />
                <span class="text-danger" asp-validation-for="EmailMFA.MFAToken"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-2">

                <input type="submit" class="btn btn-primary" value="Verify"/>
            </div>
             <div class="col-5">
                   <input type="hidden" asp-for="EmailMFA.RememberMe" />
            </div>
        </div>
    </form>
</div>